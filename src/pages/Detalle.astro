---
import Layout from "../layouts/Layout.astro";
---

<Layout>

    <section class="px-20">
        <div style="display: flex; gap: 32px; padding: 40px;">
            <div
                style="flex: 1; display: flex; justify-content: center; align-items: center; background-color: #f5f5f7; padding: 20px; border-radius: 24px;"
            >
                <img
                    src="/iphone33.png"
                    style="max-width: 100%; border-radius: 8px;"
                />
            </div>

            <div
                style="flex: 1; display: flex; flex-direction: column; gap: 24px;"
            >
                <div style="display: flex; flex-direction: column; gap: 8px;">
                    <div style="font-size: 32px; font-weight: bold;">
                        iPhone 15 Pro
                    </div>
                    <div style="font-size: 16px; color: #6e6e73;">
                        Forjado en titanio. Diseñado para llegar más lejos.
                    </div>
                </div>

                <div
                    style="display: flex; justify-content: space-between; align-items: center; background-color: #fbfbfd; padding: 20px; border-radius: 12px;"
                >
                    <div style="font-size: 24px; font-weight: bold;">
                        1.219 €
                    </div>
                    <div style="font-size: 12px; color: #86868b;">
                        Desde 50,79 €/mes*
                    </div>
                </div>

                <div style="display: flex; flex-direction: column; gap: 12px;">
                    <div
                        style="font-size: 12px; font-weight: bold; color: #86868b; text-transform: uppercase;"
                    >
                        Capacidad de almacenamiento
                    </div>

                    <div style="display: flex; gap: 16px;">
                        <div
                            style="flex: 1; display: flex; flex-direction: column; padding: 16px; border: 2px solid #0071e3; border-radius: 12px;"
                        >
                            <div style="font-weight: bold;">128 GB</div>
                            <div style="font-size: 12px; color: #86868b;">
                                Incluido
                            </div>
                        </div>
                        <div
                            style="flex: 1; display: flex; flex-direction: column; padding: 16px; border: 1px solid #d2d2d7; border-radius: 12px;"
                        >
                            <div style="font-weight: bold;">256 GB</div>
                            <div style="font-size: 12px; color: #86868b;">
                                +130 €
                            </div>
                        </div>
                    </div>
                </div>

                <div
                    style="display: flex; justify-content: center; align-items: center; background-color: #0071e3; color: white; padding-top: 16px; padding-bottom: 16px; border-radius: 100px; font-weight: bold; cursor: pointer;"
                >
                    Añadir al carrito
                </div>
            </div>
        </div>
    </section>
    <section class="px-30">
        <div style="display: flex; gap: 16px; padding: 20px 0;">
            <div
                style="display: flex; justify-content: center; align-items: center; padding: 12px; background-color: #f5f5f7; border-radius: 16px; border: 2px solid transparent; cursor: pointer;"
            >
                <img
                    src="/parte3.png"
                    style="width: 80px; height: 80px; border-radius: 8px; object-fit: cover;"
                />
            </div>

            <div
                style="display: flex; justify-content: center; align-items: center; padding: 12px; background-color: #f5f5f7; border-radius: 16px; border: 2px solid transparent; cursor: pointer;"
            >
                <img
                    src="/parte2.png"
                    style="width: 80px; height: 80px; border-radius: 8px; object-fit: cover;"
                />
            </div>

            <div
                style="display: flex; justify-content: center; align-items: center; padding: 12px; background-color: #f5f5f7; border-radius: 16px; border: 2px solid transparent; cursor: pointer;"
            >
                <img
                    src="/parte1.png"
                    style="width: 80px; height: 80px; border-radius: 8px; object-fit: cover;"
                />
            </div>
        </div>
    </section>
    <section class="py-30">
        <div
            style="padding-left: 10%; padding-right: 10%; padding-top: 60px; display: flex; flex-direction: column; gap: 40px;"
        >
            <div style="font-size: 40px; font-weight: bold;">
                Especificaciones de Grado Profesional
            </div>

            <div style="display: flex; gap: 24px;">
                <div
                    style="flex: 1.5; background-color: #0c0f2d; color: white; padding: 48px; border-radius: 28px; display: flex; flex-direction: column; justify-content: space-between; min-height: 500px;"
                >
                    <div
                        style="display: flex; flex-direction: column; gap: 16px;"
                    >
                        <div
                            style="color: #4263eb; font-weight: bold; font-size: 12px; text-transform: uppercase;"
                        >
                            Rendimiento Extremo
                        </div>
                        <div style="font-size: 56px; font-weight: bold;">
                            Chip A17 Pro.
                        </div>
                        <div
                            style="font-size: 20px; color: #86868b; max-width: 400px;"
                        >
                            La mayor revolución en la historia de las GPU de
                            Apple.
                        </div>
                    </div>
                    <div
                        style="text-align: right; font-size: 12px; color: #424245; border-top: 1px solid #1d1d1f; padding-top: 20px;"
                    >
                        6 NÚCLEOS DE CPU
                    </div>
                </div>

                <div
                    style="flex: 1; display: flex; flex-direction: column; gap: 24px;"
                >
                    <div
                        style="background-color: #f5f5f7; padding: 32px; border-radius: 28px; display: flex; flex-direction: column; gap: 20px;"
                    >
                        <div
                            style="display: flex; flex-direction: column; gap: 8px;"
                        >
                            <div
                                style="font-size: 12px; font-weight: bold; color: #86868b; text-transform: uppercase;"
                            >
                                Fotografía Computacional
                            </div>
                            <div style="font-size: 24px; font-weight: bold;">
                                Cámara Pro de 48 Mpx
                            </div>
                        </div>
                        <div style="display: flex; gap: 12px;">
                            <div
                                style="flex: 1; background-color: white; padding: 16px; border-radius: 12px; text-align: center;"
                            >
                                <div style="font-weight: bold;">24 mm</div>
                                <div style="font-size: 10px; color: #86868b;">
                                    PRINCIPAL
                                </div>
                            </div>
                            <div
                                style="flex: 1; background-color: white; padding: 16px; border-radius: 12px; text-align: center;"
                            >
                                <div style="font-weight: bold;">120 mm</div>
                                <div style="font-size: 10px; color: #86868b;">
                                    TELEOBJETIVO
                                </div>
                            </div>
                            <div
                                style="flex: 1; background-color: white; padding: 16px; border-radius: 12px; text-align: center;"
                            >
                                <div style="font-weight: bold;">13 mm</div>
                                <div style="font-size: 10px; color: #86868b;">
                                    ULTRA GRAN
                                </div>
                            </div>
                        </div>
                    </div>

                    <div style="display: flex; gap: 24px; flex: 1;">
                        <div
                            style="flex: 1; background-color: #f5f5f7; padding: 24px; border-radius: 28px; display: flex; flex-direction: column; gap: 12px;"
                        >
                            <div style="font-size: 20px; font-weight: bold;">
                                ProRes 4K
                            </div>
                            <div style="font-size: 14px; color: #6e6e73;">
                                Graba directamente en una unidad externa.
                            </div>
                        </div>
                        <div
                            style="flex: 1; background-color: #f5f5f7; padding: 24px; border-radius: 28px; display: flex; flex-direction: column; gap: 12px;"
                        >
                            <div style="font-size: 20px; font-weight: bold;">
                                USB-C 3
                            </div>
                            <div style="font-size: 14px; color: #6e6e73;">
                                Transferencia hasta 20 veces más rápida.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
    </section>

</Layout>

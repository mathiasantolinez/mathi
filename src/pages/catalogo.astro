---
import Tarjeta from "../components/Tarjeta.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
<section class="pt-32 pb-20 px-8 max-w-7xl mx-auto">
        <section class="mb-20">
            <p class="text-7xl font-bold text-on-surface mb-4">iPhone.</p>
            <p class="text-xl text-on-surface-variant max-w-xl font-medium">Diseñados para ser amados. Potencia y precisión en cada detalle.</p>
        </section>
        <section class="flex flex-col lg:flex-row gap-16">
            <aside class="w-full lg:w-64 space-y-12">
                <div>
                    <p class="text-xs font-semibold uppercase tracking-widest text-on-surface-variant mb-6">modelos</p>
                    <div>
                        //aqui van los modelos de iphone
                    </div>
                </div>
                <div>
                    <p class="text-xs font-semibold uppercase tracking-widest text-on-surface-variant mb-6">capacidad</p>
                    <div class="flex flex-col gap-4 w-full max-w-md">
                        <div class="flex gap-4">
                            <div class="flex-1 bg-slate-50 border border-slate-200 rounded-xl p-6 text-center font-bold">128 GB</div>
                            <div class="flex-1 bg-slate-50 border border-slate-200 rounded-xl p-6 text-center font-bold">256 GB</div>
                        </div>
                        <div class="flex gap-4">
                            <div class="flex-1 bg-slate-50 border border-slate-200 rounded-xl p-6 text-center font-bold">512 GB</div>
                            <div class="flex-1 bg-slate-50 border border-slate-200 rounded-xl p-6 text-center font-bold">1 TB</div>
                        </div>
                    </div>
                </div>
            </aside>
            <div class="flex-1 gap-8">
                <div class="flex gap-10">
                    <div class="group bg-surface-container-lowest rounded-xl p-8 flex flex-col justify-between hover:bg-white transition-all duration-500 overflow-hidden relative">
                        <div class="absolute top-6 right-8">
                            <p class="text-[10px] font-black uppercase tracking-widest text-tertiary bg-tertiary/10 px-2 py-1 rounded text-blue-700 ">nuevo</p>
                        </div>
                        <div class="mb-12">
                            <p class="text-3xl font-bold tracking-tight mb-2">iPhone 15 Pro</p>
                            <p class="text-lg text-on-surface-variant">Titanium. En la palma de tu mano.</p>
                        </div>
                        <div class="aspect-square flex items-center justify-center mb-12">
                            <img src="/iphone1.png" class="max-w-full h-auto object-contain transform group-hover:scale-105 transition-transform duration-700" alt="">
                        </div>
                        <div class="space-y-6">
                            <div class="flex justify-between items-end">
                                <div>
                                    <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2">colores</p>
                                </div>
                                <div class="text-right">
                                    <p class="text-sm text-on-surface-variant font-medium">desde</p>
                                    <p class="text-2xl font-bold tracking-tight">1219€</p>
                                </div>
                            </div>
                            <button class="w-full bg-neutral-500 text-on-primary py-4 rounded-full font-bold text-sm tracking-tight hover:bg-primary-dim active:scale-95 transition-all text-white">comprar</button>
                        </div>
                    </div>
                    <div class="group bg-surface-container-lowest rounded-xl p-8 flex flex-col justify-between hover:bg-white transition-all duration-500 overflow-hidden relative">
                        <div class="mb-12">
                            <p class="text-3xl font-bold tracking-tight mb-2">iPhone 15</p>
                            <p class="text-sm font-medium text-on-surface-variant">Un gran salto hacia adelante.</p>
                        </div>
                        <div class="aspect-square flex items-center justify-center mb-12">
                            <img src="/iphonepink.png" class="max-w-full h-auto object-contain transform group-hover:scale-105 transition-transform duration-700" alt="">
                        </div>
                        <div class="space-y-6">
                            <div class="flex justify-between items-end">
                                <div>
                                    <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2">colores</p>
                                </div>
                                <div class="text-right">
                                    <p class="text-sm text-on-surface-variant font-medium">desde</p>
                                    <p class="text-2xl font-bold tracking-tight">959€</p>
                                </div>
                            </div>
                            <button class="w-full bg-neutral-500 text-on-primary py-4 rounded-full font-bold text-sm tracking-tight hover:bg-primary-dim active:scale-95 transition-all text-white">comprar</button>
                        </div>
                    </div>
                </div>
                <div class="flex gap-10">
                    <div class="group bg-surface-container-lowest rounded-xl p-8 flex flex-col justify-between hover:bg-white transition-all duration-500 overflow-hidden relative">
                        <div class="mb-12">
                            <p class="text-3xl font-bold tracking-tight mb-2">iPhone 14</p>
                            <p class="text-sm font-medium text-on-surface-variant">Espectacular en todos los sentidos.</p>
                        </div>
                        <div class="aspect-square flex items-center justify-center mb-12">
                            <img src="/iphone2.png" class="max-w-full h-auto object-contain transform group-hover:scale-105 transition-transform duration-700" alt="">
                        </div>
                        <div class="space-y-6">
                            <div class="flex justify-between items-end">
                                <div>
                                    <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2">colores</p>
                                </div>
                                <div class="text-right">
                                    <p class="text-sm text-on-surface-variant font-medium">desde</p>
                                    <p class="text-2xl font-bold tracking-tight">859€</p>
                                </div>
                            </div>
                            <button class="w-full bg-neutral-500 text-on-primary py-4 rounded-full font-bold text-sm tracking-tight hover:bg-primary-dim active:scale-95 transition-all text-white">comprar</button>
                        </div>
                    </div>
                    <div class="group bg-surface-container-lowest rounded-xl p-8 flex flex-col justify-between hover:bg-white transition-all duration-500 overflow-hidden relative">
                        <div class="mb-12">
                            <p class="text-3xl font-bold tracking-tight mb-2">iPhone SE</p>
                            <p class="text-sm font-medium text-on-surface-variant">Mucho amor. Menos gasto.</p>
                        </div>
                        <div class="aspect-square flex items-center justify-center mb-12">
                            <img src="/iphoneSE.png" class="max-w-full h-auto object-contain transform group-hover:scale-105 transition-transform duration-700" alt="">
                        </div>
                        <div class="space-y-6">
                            <div class="flex justify-between items-end">
                                <div>
                                    <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2">colores</p>
                                </div>
                                <div class="text-right">
                                    <p class="text-sm text-on-surface-variant font-medium">desde</p>
                                    <p class="text-2xl font-bold tracking-tight">429€</p>
                                </div>
                            </div>
                            <button class="w-full bg-neutral-500 text-on-primary py-4 rounded-full font-bold text-sm tracking-tight hover:bg-primary-dim active:scale-95 transition-all text-white">comprar</button>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </section>
</Layout>
